generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum FileType {
  IMAGE
  PDF
  DOCUMENT
  SPREADSHEET
  OTHER
}

enum FileStatus {
  UPLOADING
  PROCESSING
  OPTIMIZED
  FAILED
}

model File {
  id                Int          @id @default(autoincrement())
  originalName      String
  storedName        String       @unique
  mimeType          String
  fileType          FileType
  size              Int
  optimizedSize     Int?
  compressionRatio  Float?
  path              String
  url               String
  status            FileStatus   @default(UPLOADING)
  uploadedById      Int
  metadata          Json?
  checksum          String
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt
  
  uploadedBy        User         @relation(fields: [uploadedById], references: [id], onDelete: Cascade)
  
  @@index([uploadedById])
  @@index([fileType])
  @@index([status])
  @@index([checksum])
  @@map("files")
}

model User {
  id    Int     @id @default(autoincrement())
  email String  @unique
  name  String?
  
  files File[]
}