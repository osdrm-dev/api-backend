generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum FileType {
  IMAGE
  PDF
  DOCUMENT
  SPREADSHEET
  OTHER
}

enum FileStatus {
  UPLOADING
  PROCESSING
  OPTIMIZED
  FAILED
}

model File {
  id                Int          @id @default(autoincrement())
  originalName      String
  storedName        String       @unique
  mimeType          String
  fileType          FileType
  size              Int
  optimizedSize     Int?
  compressionRatio  Float?
  path              String
  url               String
  status            FileStatus   @default(UPLOADING)
  uploadedById      Int
  metadata          Json?
  checksum          String
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt
  
  uploadedBy          User                 @relation(fields: [uploadedById], references: [id], onDelete: Cascade)
  attachments         Attachment[]
  budgetTables        BudgetTable[]
  signatureSpecimens  SignatureSpecimen[]

  @@index([uploadedById])
  @@index([fileType])
  @@index([status])
  @@index([checksum])
  @@map("files")
}

enum Role {
  DEMANDEUR
  OM
  CFO
  CEO
  DP
  RFR
  CPR
  ADMIN
  ACHETEUR
  CFR
}

model User {
  id                Int                @id @default(autoincrement())
  email             String             @unique
  password          String
  name              String
  fonction          String
  role              Role               @default(DEMANDEUR)
  isActive          Boolean            @default(true)
  lastLoginAt       DateTime?
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  
  refreshTokens       RefreshToken[]
  auditLogs           AuditLog[]
  validators          Validator[]
  purchasesCreated    Purchase[]           @relation("PurchaseCreator")
  files               File[]
  budgetTables        BudgetTable[]
  signatureSpecimens  SignatureSpecimen[]

  @@index([email])
  @@index([role])
  @@map("users")
}

model RefreshToken {
  id          Int       @id @default(autoincrement())
  token       String    @unique
  userId      Int
  expiresAt   DateTime
  createdAt   DateTime  @default(now())
  revokedAt   DateTime?
  replacedBy  String?
  ipAddress   String?
  userAgent   String?
  
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@index([userId])
  @@index([token])
  @@map("refresh_tokens")
}

model AuditLog {
  id          Int       @id @default(autoincrement())
  userId      Int?
  action      String
  resource    String
  resourceId  String?
  details     Json?
  ipAddress   String?
  userAgent   String?
  createdAt   DateTime  @default(now())
  
  user        User?     @relation(fields: [userId], references: [id], onDelete: SetNull)
  
  @@index([userId])
  @@index([action])
  @@index([createdAt])
  @@map("audit_logs")
}

enum OperationType {
  PROGRAMME
  OPERATION
}

enum PurchaseStep {
  DA
  QR
  PV
  BC
  BR
  INVOICE
  DAP
  PROOF_OF_PAYMENT
  DONE
}

enum PurchaseStatus {
  DRAFT
  PENDING_APPROVAL
  PUBLISHED
  AWAITING_DOCUMENTS
  VALIDATED
  REJECTED
  IN_DEROGATION
  CHANGE_REQUESTED
}

// =====================================================
// MODIFICATION: Ajout de DA_ATTACHMENT pour les pièces 
// jointes lors de la création de la demande d'achat
// =====================================================
enum AttachmentType {
  DA_ATTACHMENT     // <- NOUVEAU: Pièces jointes de la DA (étape création)
  QUOTE             // Devis (étape QR)
  INVOICE           // Facture
  PURCHASE_ORDER    // Bon de commande
  DELIVERY_NOTE     // Bon de livraison
  PROOF_OF_PAYMENT  // Preuve de paiement
  OTHER             // Autre
}

enum SigningStatus {
  PENDING
  PROCESSING
  DONE
  FAILED
}

enum DerogationStatus {
  PENDING
  VALIDATED
  REJECTED
}

enum ValidatorRole {
  ACHETEUR
  DEMANDEUR
  RFR
  CPR
  OM
  DP
  CFO
  CEO
}

model Purchase {
  id                    String              @id @default(cuid())
  reference             String              @unique
  year                  Int?
  site                  String?
  sequentialNumber      String?

  project               String?
  region                String?
  projectCode           String?
  grantCode             String?
  activityCode          String?
  costCenter            String?

  title                 String
  description           String?             @db.Text
  marketType            String?
  operationType         OperationType

  createdAt             DateTime            @default(now())
  requestedDeliveryDate DateTime?
  receivedAt            DateTime?
  closedAt              DateTime?
  validatedAt           DateTime?

  processingDuration    Int?
  priority              String?
  justification         String  

  deliveryAddress       String?             @db.Text

  status                PurchaseStatus      @default(DRAFT)
  currentStep           PurchaseStep        @default(DA)
  observations          String?             @db.Text
  responsible           String?

  creatorId             Int?
  creator               User?               @relation("PurchaseCreator", fields: [creatorId], references: [id], onDelete: SetNull)

  items                 PurchaseItem[]
  attachments           Attachment[]
  derogation            Derogation?
  validationWorkflows   ValidationWorkflow[]

  updatedAt             DateTime            @updatedAt
  pv                    PV?
  satisfactionSurvey    SatisfactionSurvey?

  @@index([reference])
  @@index([status])
  @@index([currentStep])
  @@index([project])
  @@index([region])
  @@index([creatorId])
  @@index([createdAt])
  @@map("purchases")
}

model PurchaseItem {
  id              String    @id @default(cuid())
  purchaseId      String

  designation     String
  quantity        Float
  unitPrice       Float
  amount          Float
  unit            String?
  specifications  String?   @db.Text

  purchase        Purchase  @relation(fields: [purchaseId], references: [id], onDelete: Cascade)

  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([purchaseId])
  @@map("purchase_items")
}

model Attachment {
  id              String          @id @default(cuid())
  purchaseId      String
  fileId          Int?

  type            AttachmentType
  fileName        String
  fileUrl         String
  fileSize        Int?
  mimeType        String?

  description     String?         @db.Text
  uploadedBy      String?
  receivedAt      DateTime?
  validatedAt     DateTime?

  originHash      String?
  signedHash      String?
  signingStatus   SigningStatus?
  jobId           String?
  signedAt        DateTime?
  versions        Json?

  purchase        Purchase           @relation(fields: [purchaseId], references: [id], onDelete: Cascade)
  file            File?              @relation(fields: [fileId], references: [id], onDelete: SetNull)

  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  @@index([purchaseId])
  @@index([fileId])
  @@index([type])
  @@map("attachments")
}

model Derogation {
  id                  String            @id @default(cuid())
  purchaseId          String            @unique

  reason              String            @db.Text
  justification       String            @db.Text
  status              DerogationStatus  @default(PENDING)
  validationLevel     Int               @default(0)

  approvedBy          String?
  approvedAt          DateTime?
  rejectedBy          String?
  rejectedAt          DateTime?
  comments            String?           @db.Text

  purchase            Purchase          @relation(fields: [purchaseId], references: [id], onDelete: Cascade)

  createdAt           DateTime          @default(now())
  updatedAt           DateTime          @updatedAt

  @@index([purchaseId])
  @@index([status])
  @@map("derogations")
}

model ValidationWorkflow {
  id              String        @id @default(cuid())
  purchaseId      String
  step            PurchaseStep  @default(DA)

  currentStep     Int           @default(0)
  isComplete      Boolean       @default(false)

  purchase        Purchase      @relation(fields: [purchaseId], references: [id], onDelete: Cascade)
  validators      Validator[]

  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@unique([purchaseId, step])
  @@index([purchaseId])
  @@index([step])
  @@map("validation_workflows")
}

model Validator {
  id                    String              @id @default(cuid())
  workflowId            String
  userId                Int?

  role                  ValidatorRole
  order                 Int
  name                  String?
  email                 String?

  isValidated           Boolean             @default(false)
  validatedAt           DateTime?
  comment               String?             @db.Text

  decision              String?

  workflow              ValidationWorkflow  @relation(fields: [workflowId], references: [id], onDelete: Cascade)
  user                  User?               @relation(fields: [userId], references: [id], onDelete: SetNull)

  createdAt             DateTime            @default(now())
  updatedAt             DateTime            @updatedAt

  @@index([workflowId])
  @@index([userId])
  @@index([order])
  @@map("validators")
}

model Supplier {
  id          String   @id @default(cuid())
  name        String
  status      String
  nif         String
  stat        String
  rcs         String
  region      String
  address     String
  phone       String
  email       String?
  label       String?
  pvSuppliers PVSupplier[]

  active      Boolean  @default(true)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([name])
  @@index([status])
  @@index([region])
  @@map("suppliers")
}

enum PVStatus {
  DRAFT
  SUBMITTED
  VALIDATED
  REJECTED
}

model PV {
  id              String    @id @default(cuid())
  purchaseId      String    @unique

  evaluateur      String?
  dateEvaluation  DateTime?
  natureObjet     String?
  decisionFinale  String?   @db.Text
  status          PVStatus  @default(DRAFT)

  purchase        Purchase     @relation(fields: [purchaseId], references: [id], onDelete: Cascade)
  suppliers       PVSupplier[]

  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([purchaseId])
  @@map("pvs")
}

model PVSupplier {
  id          String   @id @default(cuid())
  pvId        String
  supplierId  String?

  order   Int
  name    String?
  rang    Int?

  reponseDansDelai          String?
  annexe1                   String?
  devisSpecifications       String?
  regulariteFiscale         String?
  copiecin                  String?
  conformiteSpecs           String?
  distanceBureaux           String?
  delaiLivraison            String?
  sav                       String?
  disponibiliteArticles     String?
  qualiteArticles           String?
  experienceAnterieure      String?
  producteurOuSousTraitant  String?
  echantillonBat            String?
  validiteOffre             String?
  modePaiement              String?
  delaiPaiement             String?
  offreFinanciere           Decimal? @db.Decimal(15, 2)

  pv        PV        @relation(fields: [pvId], references: [id], onDelete: Cascade)
  supplier  Supplier? @relation(fields: [supplierId], references: [id], onDelete: SetNull)
  items     PVSupplierItem[]

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([pvId])
  @@index([supplierId])
  @@map("pv_suppliers")
}

model PVSupplierItem {
  id              String  @id @default(cuid())
  supplierId      String

  purchaseItemId  String?
  designation     String
  quantity        Float
  unitPrice       Float
  amount          Float
  disponibilite   String?
  isSelected      Boolean @default(false)

  supplier        PVSupplier  @relation(fields: [supplierId], references: [id], onDelete: Cascade)

  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([supplierId])
  @@map("pv_supplier_items")
}

enum NotificationStatus {
  PENDING
  SENT
  FAILED
  VALIDATED
  EXPIRED
}

model Notification {
  id            String             @id @default(cuid())
  type          String             
  
  resourceId    String?
  resourceType  String?            
  
  recipients    Json               
  data          Json               
  
  status        NotificationStatus @default(PENDING)
  
  hasReminder   Boolean            @default(false)
  attemptCount  Int                @default(0)
  reminderCount Int                @default(0)
  reminderIntervalInDays Int?      @default(24)
  
  lastSentAt    DateTime?
  expiredAt     DateTime?          
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt

  @@index([resourceId])
  @@index([status])
  @@index([type])
  @@index([createdAt])
  @@map("notifications")
}

model BudgetTable {
  id            Int               @id @default(autoincrement())
  version       Int
  label         String
  isPending     Boolean           @default(false)
  isActive      Boolean           @default(false)
  activatedAt   DateTime?
  uploadedById  Int
  fileId        Int

  uploadedBy    User              @relation(fields: [uploadedById], references: [id])
  file          File              @relation(fields: [fileId], references: [id])
  projects      BudgetProject[]

  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  @@index([isActive])
  @@index([isPending])
  @@index([uploadedById])
  @@map("budget_tables")
}

model BudgetProject {
  id              Int          @id @default(autoincrement())
  budgetTableId   Int
  projectName     String
  projectCode     String
  grantCode       String
  activityCode    String
  costCenter      String
  region          String
  site            String
  budgetThreshold Decimal      @db.Decimal(18, 2)

  budgetTable     BudgetTable  @relation(fields: [budgetTableId], references: [id], onDelete: Cascade)

  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  @@unique([budgetTableId, projectCode])
  @@index([budgetTableId])
  @@index([projectCode])
  @@map("budget_projects")
}

model SignatureSpecimen {
  id        Int      @id @default(autoincrement())
  userId    Int
  fileId    Int
  isActive  Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user              User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  file              File         @relation(fields: [fileId], references: [id], onDelete: Cascade)
  @@index([userId])
  @@map("signature_specimens")
}

model SatisfactionSurvey {
  id                String                     @id @default(cuid())
  purchaseId        String                     @unique
  
  rating            Int
  comment           String?                    @db.Text
  deliveryRating    Int?
  qualityRating     Int?
  serviceRating     Int?
  
  purchase          Purchase                   @relation(fields: [purchaseId], references: [id], onDelete: Cascade)
  
  createdAt         DateTime                   @default(now())
  updatedAt         DateTime                   @updatedAt
  
  @@index([purchaseId])
  @@index([rating])
  @@map("satisfaction_surveys")
}
