<!DOCTYPE html>
<html lang="fr">
<head><meta charset="UTF-8" /><title>Validation DAP requise</title></head>
<body style="margin:0;padding:0;background:#f4f6f9;font-family:Arial,sans-serif;">
  <table width="100%" cellpadding="0" cellspacing="0" style="background:#f4f6f9;padding:40px 0;">
    <tr><td align="center">
      <table width="600" cellpadding="0" cellspacing="0" style="background:#ffffff;border-radius:8px;overflow:hidden;">
        <tr>
          <td style="background:#98d44e;padding:24px 32px;">
            <p style="margin:0;color:#ffffff;font-size:20px;font-weight:bold;">OSDRM — Demande de Paiement Anticipé</p>
          </td>
        </tr>
        <tr>
          <td style="padding:32px;">
            <p style="margin:0 0 16px;font-size:16px;color:#111827;">
              {{#if isReminder}}<strong>Rappel :</strong> {{/if}}Une demande de paiement anticipé attend votre validation.
            </p>
            <table cellpadding="0" cellspacing="0" style="background:#f9fafb;border:1px solid #e5e7eb;border-radius:6px;padding:16px;width:100%;">
              <tr><td style="font-size:14px;color:#6b7280;padding:4px 0;">Référence</td><td style="font-size:14px;color:#111827;font-weight:bold;padding:4px 0;">{{reference}}</td></tr>
              {{#if montant}}<tr><td style="font-size:14px;color:#6b7280;padding:4px 0;">Montant</td><td style="font-size:14px;color:#111827;padding:4px 0;">{{montant}}</td></tr>{{/if}}
            </table>
            <p style="margin:24px 0 0;font-size:13px;color:#9ca3af;">Cet email a été envoyé automatiquement par OSDRM. Merci de ne pas y répondre.</p>
          </td>
        </tr>
      </table>
    </td></tr>
  </table>
</body>
</html>
