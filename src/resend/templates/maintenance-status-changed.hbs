<!DOCTYPE html>
<html lang="fr">
<head><meta charset="UTF-8" /><title>Mise à jour demande d'entretien</title></head>
<body style="margin:0;padding:0;background:#f4f6f9;font-family:Arial,sans-serif;">
  <table width="100%" cellpadding="0" cellspacing="0" style="background:#f4f6f9;padding:40px 0;">
    <tr><td align="center">
      <table width="600" cellpadding="0" cellspacing="0" style="background:#ffffff;border-radius:8px;overflow:hidden;">
        <tr>
          <td style="background:#98d44e;padding:24px 32px;">
            <p style="margin:0;color:#ffffff;font-size:20px;font-weight:bold;">OSDRM — Demande d'entretien mise à jour</p>
          </td>
        </tr>
        <tr>
          <td style="padding:32px;">
            <p style="margin:0 0 16px;font-size:16px;color:#111827;">
              Le statut de votre demande d'entretien a été mis à jour.
            </p>
            <table cellpadding="0" cellspacing="0" style="background:#f9fafb;border:1px solid #e5e7eb;border-radius:6px;padding:16px;width:100%;margin-bottom:20px;">
              <tr>
                <td style="font-size:14px;color:#6b7280;padding:4px 0;width:140px;">Référence</td>
                <td style="font-size:14px;color:#111827;font-weight:bold;padding:4px 0;">{{reference}}</td>
              </tr>
              <tr>
                <td style="font-size:14px;color:#6b7280;padding:4px 0;">Objet</td>
                <td style="font-size:14px;color:#111827;padding:4px 0;">{{title}}</td>
              </tr>
              <tr>
                <td style="font-size:14px;color:#6b7280;padding:4px 0;">Nouveau statut</td>
                <td style="font-size:14px;color:#111827;font-weight:bold;padding:4px 0;">{{newStatus}}</td>
              </tr>
            </table>
            {{#if adminNote}}
            <table cellpadding="0" cellspacing="0" style="background:#eff6ff;border-left:4px solid #98d44e;border-radius:0 6px 6px 0;padding:16px;width:100%;margin-bottom:24px;">
              <tr>
                <td>
                  <p style="margin:0 0 6px;font-size:12px;font-weight:bold;color:#98d44e;text-transform:uppercase;letter-spacing:0.05em;">Note de l'administrateur</p>
                  <p style="margin:0;font-size:15px;color:#1e3a5f;line-height:1.6;">{{adminNote}}</p>
                </td>
              </tr>
            </table>
            {{/if}}
            {{#if requestUrl}}
            <table cellpadding="0" cellspacing="0" width="100%" style="margin-bottom:24px;">
              <tr>
                <td align="center">
                  <a href="{{requestUrl}}"
                     style="display:inline-block;background:#98d44e;color:#ffffff;font-size:14px;font-weight:bold;text-decoration:none;padding:12px 28px;border-radius:6px;">
                    Voir la demande
                  </a>
                </td>
              </tr>
            </table>
            {{/if}}
            <p style="margin:0;font-size:13px;color:#9ca3af;">Cet email a été envoyé automatiquement par OSDRM. Merci de ne pas y répondre.</p>
          </td>
        </tr>
      </table>
    </td></tr>
  </table>
</body>
</html>
