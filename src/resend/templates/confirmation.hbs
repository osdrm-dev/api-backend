            <table cellpadding="0" cellspacing="0">
              <tr>
                <td style="background:#98d44e;border-radius:6px;padding:12px 24px;">
                  <a href="{{link}}" style="color:#ffffff;font-size:14px;font-weight:bold;text-decoration:none;">Réinitialiser mon mot de passe</a>
                </td>
              </tr>
            </table>
            <p style="margin:24px 0 0;font-size:13px;color:#9ca3af;">
